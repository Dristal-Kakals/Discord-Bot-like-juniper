DISCORD_TOKEN=your_bot_token_here
DISCORD_CLIENT_ID=your_application_client_id_here
DISCORD_CLIENT_SECRET=your_application_client_secret_here
DISCORD_GUILD_ID=your_test_server_id_here

# Required for welcome, autorole, logs, levels, automod and Telegram Discord->TG text.
# Also enable Server Members Intent and Message Content Intent in Discord Developer Portal.
ENABLE_PRIVILEGED_INTENTS=true

# Telegram bridge
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Dashboard
WEB_PORT=3555
WEB_PUBLIC_URL=https://144.31.235.172:3555
WEB_SSL_KEY=/opt/dsbot/certs/key.pem
WEB_SSL_CERT=/opt/dsbot/certs/cert.pem
